# arbc-membership BFF — copy to .env and adjust.
PORT=8080
GIN_MODE=debug

# Upstream KreaZcy engines (localhost in dev, internal Docker DNS in prod).
KONSUMZCY_URL=http://localhost:8084
PROMOZCY_URL=http://localhost:8082
NOTIFIKAZCY_URL=http://localhost:8086
AGREGAZCY_URL=http://localhost:5900

# Brand / campaign config (vocabulary lives in the BFF, never the engines).
DEFAULT_CAMPAIGN=launch-free-coffee
COFFEE_PRICE=20000

# Voucher delivery: false → code returned in the API response (ship without Resend).
NOTIFY_ENABLED=false
